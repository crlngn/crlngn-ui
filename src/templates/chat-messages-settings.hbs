<section
  class="form-content tab {{#if tab.active}} active{{/if}}" data-group="{{tab.group}}" data-tab="{{tab.id}}"
>
  <h4><i class="fas fa-user"></i> {{localize "CRLNGN_UI.ui.clientSettingsLabel"}} <span class="toggle-hint">{{localize 'CRLNGN_UI.ui.toggleHints'}}</span></h4>
  <hr/>
  {{!-- <h2>{{localize "CRLNGN_UI.settings.customFontsDialog.label"}}</h2> --}}
  <p class="hint">{{localize "CRLNGN_UI.settings.sidebarMenu.hint"}}</p>

  <div class="form-group range">
    <label for="sideBarWidth">{{fields.sideBarWidth.label}}</label>
    <input type="range" name="sideBarWidth" min="280" max="380" value="{{sideBarWidth}}" {{#if fields.sideBarWidth.isLocked}}disabled{{/if}} />
    <input type="number" name="sideBarWidth_value" class="range-value-input" value="{{sideBarWidth}}" {{#if fields.sideBarWidth.isLocked}}disabled{{/if}} />
    <p class="hint">{{{fields.sideBarWidth.hint}}}</p>
  </div>

  <div class="form-group">
    <label for="enableChatStyles">{{fields.enableChatStyles.label}}</label>
    <input type="checkbox" name="enableChatStyles" {{#if enableChatStyles}}checked{{/if}} {{#if fields.enableChatStyles.isLocked}}disabled{{/if}} />
    <p class="hint">{{fields.enableChatStyles.hint}}</p>
  </div>

  <div class="form-group">
    <label for="chatBorderColor">{{fields.chatBorderColor.label}}</label>
    <select name="chatBorderColor" {{#if fields.chatBorderColor.isLocked}}disabled{{/if}}>
      {{#each fields.chatBorderColor.options}}
      <option value="{{@key}}" {{#if (eq @key ../chatBorderColor)}}selected{{/if}}>
        {{this}}
      </option>
      {{/each}}
    </select>
    <p class="hint">{{{fields.chatBorderColor.hint}}}</p>
  </div>

  <div class="form-group">
    <label for="chatBorderPosition">{{fields.chatBorderPosition.label}}</label>
    <select name="chatBorderPosition" {{#if fields.chatBorderPosition.isLocked}}disabled{{/if}}>
      {{#each fields.chatBorderPosition.options}}
      <option value="{{@key}}" {{#if (eq @key ../chatBorderPosition)}}selected{{/if}}>
        {{this}}
      </option>
      {{/each}}
    </select>
    <p class="hint">{{{fields.chatBorderPosition.hint}}}</p>
  </div>

  <div class="form-group">
    <label for="openChatLogOnLoad">{{fields.openChatLogOnLoad.label}}</label>
    <input type="checkbox" name="openChatLogOnLoad" {{#if openChatLogOnLoad}}checked{{/if}} {{#if fields.openChatLogOnLoad.isLocked}}disabled{{/if}} />
    <p class="hint">{{fields.openChatLogOnLoad.hint}}</p>
  </div>

  <div class="form-group">
    <label for="closeSidebarWhenIdle">{{fields.closeSidebarWhenIdle.label}}</label>
    <input type="checkbox" name="closeSidebarWhenIdle" {{#if closeSidebarWhenIdle}}checked{{/if}} {{#if fields.closeSidebarWhenIdle.isLocked}}disabled{{/if}} />
    <p class="hint">{{fields.closeSidebarWhenIdle.hint}}</p>
  </div>

  <div class="form-group">
    <label for="useHorizontalSidebarTabs">{{fields.useHorizontalSidebarTabs.label}}</label>
    <input type="checkbox" name="useHorizontalSidebarTabs" {{#if useHorizontalSidebarTabs}}checked{{/if}} {{#if fields.useHorizontalSidebarTabs.isLocked}}disabled{{/if}} />
    <p class="hint">{{fields.useHorizontalSidebarTabs.hint}}</p>
  </div>

  <div class="form-group">
    <label for="showChatNotificationsOnTop">{{fields.showChatNotificationsOnTop.label}}</label>
    <input type="checkbox" name="showChatNotificationsOnTop" {{#if showChatNotificationsOnTop}}checked{{/if}} {{#if fields.showChatNotificationsOnTop.isLocked}}disabled{{/if}} />
    <p class="hint">{{fields.showChatNotificationsOnTop.hint}}</p>
  </div>

  <div class="form-group">
    <label for="useFolderStyle">{{fields.useFolderStyle.label}}</label>
    <input type="checkbox" name="useFolderStyle" {{#if useFolderStyle}}checked{{/if}} {{#if fields.useFolderStyle.isLocked}}disabled{{/if}} />
    <p class="hint">{{{fields.useFolderStyle.hint}}}</p>
  </div>

  {{#if isGM}}
  <p>&nbsp;</p>
  <h4><i class="fas fa-globe"></i> {{localize "CRLNGN_UI.ui.worldSettingsLabel"}} <span class="toggle-hint">{{localize 'CRLNGN_UI.ui.toggleHints'}}</span></h4>
  <hr/>

  <div class="form-group sidebar-tabs-visibility">
    <label>{{fields.hiddenSidebarTabs.label}}</label>
    <p class="hint">{{fields.hiddenSidebarTabs.hint}}</p>
    <div class="sidebar-tabs-list" data-drag-container="sidebar-tabs">
      <div class="sidebar-tab-row header-row">
        <span class="drag-handle"></span>
        <span class="tab-icon"></span>
        <span class="tab-name">{{localize "CRLNGN_UI.settings.sidebarTabs.tabsColumn"}}</span>
        <span class="hide-option-header">{{localize "CRLNGN_UI.settings.sidebarTabs.gmHideColumn"}}</span>
        <span class="hide-option-header">{{localize "CRLNGN_UI.settings.sidebarTabs.playerHideColumn"}}</span>
      </div>
      {{#each sidebarTabs}}
      <div class="sidebar-tab-row" data-tab-name="{{this.name}}" draggable="true">
        <span class="drag-handle"><i class="fas fa-grip-vertical"></i></span>
        <span class="tab-icon"><i class="{{this.icon}}"></i></span>
        <span class="tab-name">{{this.label}}</span>
        <label class="hide-option">
          <input type="checkbox" name="hideTab_{{this.name}}_gm" {{#if this.hideForGM}}checked{{/if}} />
        </label>
        <label class="hide-option">
          <input type="checkbox" name="hideTab_{{this.name}}_player" {{#if this.hideForPlayer}}checked{{/if}} />
        </label>
      </div>
      {{/each}}
    </div>
  </div>
  {{/if}}

  {{!-- <div class="form-group">
    <label for="useLeftChatBorder">{{fields.useLeftChatBorder.label}}</label>
    <input type="checkbox" name="useLeftChatBorder" {{#if useLeftChatBorder}}checked{{/if}} />
    <p class="hint">{{fields.useLeftChatBorder.hint}}</p>
  </div> --}}
</section>
