<menu class="contents">
  {{#each folders}}
  <li class="folder" data-folder-id="{{this.id}}">
    <div class="folder-item" data-folder-id="{{this.id}}">
      <i class="fa-solid"></i>
      <span class="folder-name ellipsis">{{this.name}}</span>
    </div>
  </li>
  {{/each}}

  {{#each scenes}}
  <li class="ui-control scene {{this.cssClass}} {{#if this.isGM}}crlngn{{/if}}" data-scene-id="{{this.id}}">
    <span class="scene-name ellipsis">{{this.name}}</span>
    {{#if this.users}}
    <ul class="scene-players">
      {{#each this.users}}
      <li class="scene-player" style="--color-bg:{{this.color}}; --color-border:{{this.border}}"
          data-tooltip aria-label="{{this.name}}">{{this.letter}}</li>
      {{/each}}
    </ul>
    {{/if}}
    {{> "modules/crlngn-ui/templates/scene-nav-preview.hbs" scene=this}}
  </li>
  {{/each}}
</menu>