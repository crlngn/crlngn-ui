<section
  class="form-content tab {{#if tab.active}} active{{/if}}" data-group="{{tab.group}}" data-tab="{{tab.id}}"
>
  <h4>
    <i class="fas fa-user"></i> {{localize "CRLNGN_UI.ui.clientSettingsLabel"}}
    <span class="toggle-hint">{{localize 'CRLNGN_UI.ui.toggleHints'}}</span>
  </h4>
  <hr/>

  <div class="form-group">
    <label for="enableCombatTrackerCarousel">{{fields.enableCombatTrackerCarousel.label}}</label>
    <input type="checkbox" name="enableCombatTrackerCarousel" {{#if enableCombatTrackerCarousel}}checked{{/if}} {{#if fields.enableCombatTrackerCarousel.isLocked}}disabled{{/if}} />
    <p class="hint">{{fields.enableCombatTrackerCarousel.hint}}</p>
  </div>

  <div class="form-group">
    <label for="autoPopoutOnCombatStart">{{fields.autoPopoutOnCombatStart.label}}</label>
    <input type="checkbox" name="autoPopoutOnCombatStart" {{#if autoPopoutOnCombatStart}}checked{{/if}} {{#if fields.autoPopoutOnCombatStart.isLocked}}disabled{{/if}} />
    <p class="hint">{{fields.autoPopoutOnCombatStart.hint}}</p>
  </div>

  <div class="form-group">
    <label for="combatTrackerTakeFullWidth">{{fields.combatTrackerTakeFullWidth.label}}</label>
    <input type="checkbox" name="combatTrackerTakeFullWidth" {{#if combatTrackerTakeFullWidth}}checked{{/if}} {{#if fields.combatTrackerTakeFullWidth.isLocked}}disabled{{/if}} />
    <p class="hint">{{fields.combatTrackerTakeFullWidth.hint}}</p>
  </div>

  <div class="form-group">
    <label for="combatCarouselScale">{{fields.combatCarouselScale.label}}</label>
    <div class="form-fields">
      <input type="range" name="combatCarouselScale" min="0.7" max="1.5" step="0.1" value="{{combatCarouselScale}}" {{#if fields.combatCarouselScale.isLocked}}disabled{{/if}} />
      <input type="number" name="combatCarouselScale_value" class="range-value-input" min="0.7" max="1.5" step="0.1" value="{{combatCarouselScale}}" {{#if fields.combatCarouselScale.isLocked}}disabled{{/if}} />
    </div>
    <p class="hint">{{fields.combatCarouselScale.hint}}</p>
  </div>

  <div class="form-group">
    <label for="dockedCarouselOffset">{{fields.dockedCarouselOffset.label}}</label>
    <div class="form-fields">
      <input type="number" name="dockedCarouselOffset" min="0" step="1" value="{{dockedCarouselOffset}}" {{#if fields.dockedCarouselOffset.isLocked}}disabled{{/if}} />
    </div>
    <p class="hint">{{fields.dockedCarouselOffset.hint}}</p>
  </div>

  <div class="form-group">
    <label for="carouselDockOnLoad">{{fields.carouselDockOnLoad.label}}</label>
    <select name="carouselDockOnLoad" {{#if fields.carouselDockOnLoad.isLocked}}disabled{{/if}}>
      <option value="preserve" {{#if (eq carouselDockOnLoad "preserve")}}selected{{/if}}>{{localize "CRLNGN_UI.settings.combatTrackerMenu.fields.carouselDockOnLoad.options.preserve"}}</option>
      <option value="top" {{#if (eq carouselDockOnLoad "top")}}selected{{/if}}>{{localize "CRLNGN_UI.settings.combatTrackerMenu.fields.carouselDockOnLoad.options.top"}}</option>
      <option value="bottom" {{#if (eq carouselDockOnLoad "bottom")}}selected{{/if}}>{{localize "CRLNGN_UI.settings.combatTrackerMenu.fields.carouselDockOnLoad.options.bottom"}}</option>
    </select>
    <p class="hint">{{fields.carouselDockOnLoad.hint}}</p>
  </div>

  <div class="form-group">
    <label for="carouselImageSource">{{fields.carouselImageSource.label}}</label>
    <select name="carouselImageSource" {{#if fields.carouselImageSource.isLocked}}disabled{{/if}}>
      <option value="token" {{#if (eq carouselImageSource "token")}}selected{{/if}}>{{localize "CRLNGN_UI.settings.combatTrackerMenu.fields.carouselImageSource.options.token"}}</option>
      <option value="actor" {{#if (eq carouselImageSource "actor")}}selected{{/if}}>{{localize "CRLNGN_UI.settings.combatTrackerMenu.fields.carouselImageSource.options.actor"}}</option>
    </select>
    <p class="hint">{{fields.carouselImageSource.hint}}</p>
  </div>

  <div class="form-group">
    <label for="combatTrackerLayout">{{fields.combatTrackerLayout.label}}</label>
    <select name="combatTrackerLayout" {{#if fields.combatTrackerLayout.isLocked}}disabled{{/if}}>
      <option value="carousel" {{#if (eq combatTrackerLayout "carousel")}}selected{{/if}}>{{localize "CRLNGN_UI.settings.combatTrackerMenu.fields.combatTrackerLayout.options.carousel"}}</option>
      <option value="simple" {{#if (eq combatTrackerLayout "simple")}}selected{{/if}}>{{localize "CRLNGN_UI.settings.combatTrackerMenu.fields.combatTrackerLayout.options.simple"}}</option>
    </select>
    <p class="hint">{{fields.combatTrackerLayout.hint}}</p>
  </div>

  <div class="form-group">
    <label for="carouselHideDefeated">{{fields.carouselHideDefeated.label}}</label>
    <input type="checkbox" name="carouselHideDefeated" {{#if carouselHideDefeated}}checked{{/if}} {{#if fields.carouselHideDefeated.isLocked}}disabled{{/if}} />
    <p class="hint">{{fields.carouselHideDefeated.hint}}</p>
  </div>

  <div class="form-group">
    <label for="carouselRequirePlayerOwner">{{fields.carouselRequirePlayerOwner.label}}</label>
    <input type="checkbox" name="carouselRequirePlayerOwner" {{#if carouselRequirePlayerOwner}}checked{{/if}} {{#if fields.carouselRequirePlayerOwner.isLocked}}disabled{{/if}} />
    <p class="hint">{{fields.carouselRequirePlayerOwner.hint}}</p>
  </div>

  {{#if isGM}}
  <p>&nbsp;</p>
  <h4>
    <i class="fas fa-globe"></i> {{localize "CRLNGN_UI.ui.worldSettingsLabel"}}
  </h4>
  <hr/>

  <div class="form-group">
    <label for="carouselShowAllHP">{{fields.carouselShowAllHP.label}}</label>
    <select name="carouselShowAllHP" {{#if fields.carouselShowAllHP.isLocked}}disabled{{/if}}>
      <option value="gmOnly" {{#if (eq carouselShowAllHP "gmOnly")}}selected{{/if}}>{{localize "CRLNGN_UI.settings.combatTrackerMenu.fields.carouselShowAllHP.options.gmOnly"}}</option>
      <option value="all" {{#if (eq carouselShowAllHP "all")}}selected{{/if}}>{{localize "CRLNGN_UI.settings.combatTrackerMenu.fields.carouselShowAllHP.options.all"}}</option>
      <option value="disabled" {{#if (eq carouselShowAllHP "disabled")}}selected{{/if}}>{{localize "CRLNGN_UI.settings.combatTrackerMenu.fields.carouselShowAllHP.options.disabled"}}</option>
    </select>
    <p class="hint">{{fields.carouselShowAllHP.hint}}</p>
  </div>

  <div class="form-group">
    <label for="carouselTrackedResource">{{fields.carouselTrackedResource.label}}</label>
    <select name="carouselTrackedResource" {{#if fields.carouselTrackedResource.isLocked}}disabled{{/if}}>
      <option value="">— None —</option>
      {{#each trackedResourceChoices}}
      <option value="{{this.value}}" {{#if this.selected}}selected{{/if}}>{{this.label}}</option>
      {{/each}}
    </select>
    <p class="hint">{{fields.carouselTrackedResource.hint}}</p>
  </div>

  <div class="form-group">
    <label for="showCombatRoundButtons">{{fields.showCombatRoundButtons.label}}</label>
    <input type="checkbox" name="showCombatRoundButtons" {{#if showCombatRoundButtons}}checked{{/if}} {{#if fields.showCombatRoundButtons.isLocked}}disabled{{/if}} />
    <p class="hint">{{fields.showCombatRoundButtons.hint}}</p>
  </div>

  <div class="form-group">
    <label for="autoRollNPCsOnCombatStart">{{fields.autoRollNPCsOnCombatStart.label}}</label>
    <input type="checkbox" name="autoRollNPCsOnCombatStart" {{#if autoRollNPCsOnCombatStart}}checked{{/if}} {{#if fields.autoRollNPCsOnCombatStart.isLocked}}disabled{{/if}} />
    <p class="hint">{{fields.autoRollNPCsOnCombatStart.hint}}</p>
  </div>
  {{/if}}

</section>
