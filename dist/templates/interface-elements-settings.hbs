<section
  class="form-content tab {{#if tab.active}} active{{/if}}" data-group="{{tab.group}}" data-tab="{{tab.id}}"
>
  <h4>
    <i class="fas fa-user"></i> {{localize "CRLNGN_UI.ui.clientSettingsLabel"}} 
    <span class="toggle-hint">{{localize 'CRLNGN_UI.ui.toggleHints'}}</span>
  </h4>
  <hr/>

  <div class="form-group interface-elements">
    <header class="table-header flexrow">
      <div>{{localize "CRLNGN_UI.settings.interfaceOptionsMenu.fields.elementColumn"}}</div>
      <div>{{localize "CRLNGN_UI.settings.interfaceOptionsMenu.fields.fadeOutColumn"}}</div>
      <div>{{localize "CRLNGN_UI.settings.interfaceOptionsMenu.fields.customLayoutColumn"}}</div>
      <div>{{localize "CRLNGN_UI.settings.interfaceOptionsMenu.fields.hideColumn"}}</div>
    </header>
    <ul class="elements-list flexrow">
      <li>
        <label>{{localize "CRLNGN_UI.settings.interfaceOptionsMenu.fields.sceneControls"}}</label>
        <div><input type="checkbox" name="sceneControlsFadeOut" {{#if sceneControlsFadeOut}}checked{{/if}} {{#if fields.sceneControlsFadeOut.isLocked}}disabled{{/if}} /></div>
        <div><input type="checkbox" name="enableSceneControls" {{#if enableSceneControls}}checked{{/if}} {{#if fields.sceneControlsFadeOut.isLocked}}disabled{{/if}} /></div>
        <div><input type="checkbox" name="sceneControlsHide" {{#if sceneControlsHide}}checked{{/if}} {{#if fields.sceneControlsFadeOut.isLocked}}disabled{{/if}} /></div>
      </li>
      <li>
        <label>{{localize "CRLNGN_UI.settings.interfaceOptionsMenu.fields.sidebarTabs"}}</label>
        <div><input type="checkbox" name="sidebarTabsFadeOut" {{#if sidebarTabsFadeOut}}checked{{/if}} {{#if fields.sidebarTabsFadeOut.isLocked}}disabled{{/if}} /></div>
        <div><input type="checkbox" name="enableSidebarTabs" {{#if enableSidebarTabs}}checked{{/if}} {{#if fields.sidebarTabsFadeOut.isLocked}}disabled{{/if}} /></div>
        <div><input type="checkbox" name="sidebarTabsHide" {{#if sidebarTabsHide}}checked{{/if}} {{#if fields.sidebarTabsFadeOut.isLocked}}disabled{{/if}} /></div>
      </li>
      <li>
        <label>{{localize "CRLNGN_UI.settings.interfaceOptionsMenu.fields.chatLogControls"}}</label>
        <div><input type="checkbox" name="chatLogControlsFadeOut" {{#if chatLogControlsFadeOut}}checked{{/if}} {{#if fields.chatLogControlsFadeOut.isLocked}}disabled{{/if}} /></div>
        <div><input type="checkbox" name="enableChatLogControls" {{#if enableChatLogControls}}checked{{/if}} {{#if fields.chatLogControlsFadeOut.isLocked}}disabled{{/if}} /></div>
        <div><input type="checkbox" name="chatLogControlsHide" {{#if chatLogControlsHide}}checked{{/if}} {{#if fields.chatLogControlsFadeOut.isLocked}}disabled{{/if}} /></div>
      </li>
      <li>
        <label>{{localize "CRLNGN_UI.settings.interfaceOptionsMenu.fields.playerList"}}</label>
        <div><input type="checkbox" name="playerListFadeOut" {{#if playerListFadeOut}}checked{{/if}} {{#if fields.playerListFadeOut.isLocked}}disabled{{/if}} /></div>
        <div><input type="checkbox" name="enablePlayerList" {{#if enablePlayerList}}checked{{/if}} {{#if fields.playerListFadeOut.isLocked}}disabled{{/if}} /></div>
        <div><input type="checkbox" name="playerListHide" {{#if playerListHide}}checked{{/if}} {{#if fields.playerListFadeOut.isLocked}}disabled{{/if}} /></div>
      </li>
      <li>
        <label>{{localize "CRLNGN_UI.settings.interfaceOptionsMenu.fields.cameraDock"}}</label>
        <div><input type="checkbox" name="cameraDockFadeOut" {{#if cameraDockFadeOut}}checked{{/if}} {{#if fields.cameraDockFadeOut.isLocked}}disabled{{/if}} /></div>
        <div><input type="checkbox" name="enableFloatingDock" {{#if enableFloatingDock}}checked{{/if}} {{#if fields.cameraDockFadeOut.isLocked}}disabled{{/if}} /></div>
        <div><input type="checkbox" name="cameraDockHide" {{#if cameraDockHide}}checked{{/if}} {{#if fields.cameraDockFadeOut.isLocked}}disabled{{/if}} /></div>
      </li>
      <li>
        <label>{{localize "CRLNGN_UI.settings.interfaceOptionsMenu.fields.macroHotbar"}}</label>
        <div><input type="checkbox" name="macroHotbarFadeOut" {{#if macroHotbarFadeOut}}checked{{/if}} {{#if fields.macroHotbarFadeOut.isLocked}}disabled{{/if}} /></div>
        <div><input type="checkbox" name="enableMacroLayout" {{#if enableMacroLayout}}checked{{/if}} {{#if fields.macroHotbarFadeOut.isLocked}}disabled{{/if}} /></div>
        <div><input type="checkbox" name="macroHotbarHide" {{#if macroHotbarHide}}checked{{/if}} {{#if fields.macroHotbarFadeOut.isLocked}}disabled{{/if}} /></div>
      </li>
      <li>
        <label>{{localize "CRLNGN_UI.settings.interfaceOptionsMenu.fields.sceneNav"}}</label>
        <div><input type="checkbox" name="sceneNavFadeOut" {{#if sceneNavFadeOut}}checked{{/if}} {{#if fields.sceneNavFadeOut.isLocked}}disabled{{/if}} /></div>
        <div><input type="checkbox" name="sceneNavEnabled" {{#if sceneNavEnabled}}checked{{/if}} {{#if fields.sceneNavFadeOut.isLocked}}disabled{{/if}} /></div>
        <div><input type="checkbox" name="sceneNavHide" {{#if sceneNavHide}}checked{{/if}} {{#if fields.sceneNavFadeOut.isLocked}}disabled{{/if}} /></div>
      </li>
    </ul>
  </div>
  <p class="hint">{{localize "CRLNGN_UI.settings.interfaceOptionsMenu.hint"}}</p>

<hr />
  <div class="form-group">
    <label for="controlsAutoHide">{{fields.controlsAutoHide.label}}</label>
    <input type="checkbox" name="controlsAutoHide" {{#if controlsAutoHide}}checked{{/if}} {{#if fields.controlsAutoHide.isLocked}}disabled{{/if}} />
    <p class="hint">{{fields.controlsAutoHide.hint}}</p>
  </div>

  <div class="form-group">
    <label for="collapseMacroBar">{{fields.collapseMacroBar.label}}</label>
    <input type="checkbox" name="collapseMacroBar" {{#if collapseMacroBar}}checked{{/if}} {{#if fields.collapseMacroBar.isLocked}}disabled{{/if}} />
    <p class="hint">{{{fields.collapseMacroBar.hint}}}</p>
  </div>

  <div class="form-group">
    <label for="hoverableSettingsHints">{{fields.hoverableSettingsHints.label}}</label>
    <input type="checkbox" name="hoverableSettingsHints" {{#if hoverableSettingsHints}}checked{{/if}} {{#if fields.hoverableSettingsHints.isLocked}}disabled{{/if}} />
    <p class="hint">{{fields.hoverableSettingsHints.hint}}</p>
  </div>

  <div class="form-group">
    <label for="preventMacroBarReposition">{{fields.preventMacroBarReposition.label}}</label>
    <input type="checkbox" name="preventMacroBarReposition" {{#if preventMacroBarReposition}}checked{{/if}} {{#if fields.preventMacroBarReposition.isLocked}}disabled{{/if}} />
    <p class="hint">{{fields.preventMacroBarReposition.hint}}</p>
  </div>

</section>